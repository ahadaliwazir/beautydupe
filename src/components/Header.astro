---
---

<header class="sticky top-0 z-50 bg-white border-b border-stone-200">
	<nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
		<a href="/" class="text-xl font-bold tracking-tight no-underline">
			<span class="text-stone-900">Beauty</span><span class="text-rose-500">Dupe</span>
		</a>

		<!-- Desktop nav -->
		<div class="hidden md:flex items-center gap-8">
			<a href="/" class="text-sm font-medium text-stone-600 hover:text-rose-500 no-underline transition-colors">Home</a>
			<a href="/category/beauty-tech" class="text-sm font-medium text-stone-600 hover:text-rose-500 no-underline transition-colors">Beauty Tech</a>
			<a href="/category/dupes" class="text-sm font-medium text-stone-600 hover:text-rose-500 no-underline transition-colors">Dupes</a>
			<a href="/category/mens-grooming" class="text-sm font-medium text-stone-600 hover:text-rose-500 no-underline transition-colors">Men's Grooming</a>
			<a href="/about" class="text-sm font-medium text-stone-600 hover:text-rose-500 no-underline transition-colors">About</a>
		</div>

		<!-- Mobile hamburger -->
		<button
			id="mobile-menu-btn"
			class="md:hidden p-2 text-stone-600 hover:text-rose-500"
			aria-label="Toggle menu"
			aria-expanded="false"
		>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
		</button>
	</nav>

	<!-- Mobile menu -->
	<div id="mobile-menu" class="hidden md:hidden border-t border-stone-100 bg-white">
		<div class="px-4 py-3 space-y-2">
			<a href="/" class="block text-sm font-medium text-stone-600 hover:text-rose-500 no-underline py-2">Home</a>
			<a href="/category/beauty-tech" class="block text-sm font-medium text-stone-600 hover:text-rose-500 no-underline py-2">Beauty Tech</a>
			<a href="/category/dupes" class="block text-sm font-medium text-stone-600 hover:text-rose-500 no-underline py-2">Dupes</a>
			<a href="/category/mens-grooming" class="block text-sm font-medium text-stone-600 hover:text-rose-500 no-underline py-2">Men's Grooming</a>
			<a href="/about" class="block text-sm font-medium text-stone-600 hover:text-rose-500 no-underline py-2">About</a>
		</div>
	</div>
</header>

<script>
	const btn = document.getElementById('mobile-menu-btn');
	const menu = document.getElementById('mobile-menu');
	btn?.addEventListener('click', () => {
		const expanded = btn.getAttribute('aria-expanded') === 'true';
		btn.setAttribute('aria-expanded', String(!expanded));
		menu?.classList.toggle('hidden');
	});
</script>
