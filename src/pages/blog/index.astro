---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function categoryLabel(cat: string) {
	switch(cat) {
		case 'beauty-tech': return 'Beauty Tech';
		case 'dupes': return 'Dupes';
		case 'mens-grooming': return "Men's Grooming";
		case 'guides': return 'Guides';
		default: return cat;
	}
}

function categoryColor(cat: string) {
	switch(cat) {
		case 'beauty-tech': return 'text-rose-500 bg-rose-50';
		case 'dupes': return 'text-amber-600 bg-amber-50';
		case 'mens-grooming': return 'text-stone-600 bg-stone-100';
		case 'guides': return 'text-blue-600 bg-blue-50';
		default: return 'text-stone-600 bg-stone-100';
	}
}
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blog — ${SITE_TITLE}`} description="All reviews, dupes, and grooming guides." />
	</head>
	<body class="bg-white font-sans text-stone-900 antialiased">
		<Header />

		<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<div class="mb-10">
				<h1 class="text-3xl sm:text-4xl font-bold text-stone-900">All Articles</h1>
				<p class="mt-2 text-stone-500">Reviews, comparisons, and guides for every beauty budget.</p>
			</div>

			<!-- Category filters (visual) -->
			<div class="flex flex-wrap gap-2 mb-10">
				<span class="inline-block text-xs font-semibold text-rose-500 bg-rose-50 px-3 py-1.5 rounded-full">Beauty Tech</span>
				<span class="inline-block text-xs font-semibold text-amber-600 bg-amber-50 px-3 py-1.5 rounded-full">Dupes</span>
				<span class="inline-block text-xs font-semibold text-stone-600 bg-stone-100 px-3 py-1.5 rounded-full">Men's Grooming</span>
			</div>

			<!-- Posts grid -->
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
				{posts.map(post => (
					<a href={`/blog/${post.id}`} class="group no-underline">
						<article class="bg-white rounded-xl border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow h-full">
							<div class="h-44 bg-rose-50 flex items-center justify-center">
								<span class="text-rose-200 text-sm">Image</span>
							</div>
							<div class="p-5">
								<span class={`inline-block text-xs font-semibold px-2 py-1 rounded-full mb-3 ${categoryColor(post.data.category)}`}>
									{categoryLabel(post.data.category)}
								</span>
								<h3 class="font-semibold text-stone-900 group-hover:text-rose-500 transition-colors line-clamp-2">{post.data.title}</h3>
								<p class="mt-2 text-sm text-stone-500 line-clamp-2">{post.data.description}</p>
								<div class="mt-3 flex items-center justify-between">
									{post.data.price && <span class="text-sm font-semibold text-stone-700">{post.data.price}</span>}
									{post.data.rating && <span class="text-sm text-amber-500">{'★'.repeat(Math.round(post.data.rating))}{'☆'.repeat(5 - Math.round(post.data.rating))}</span>}
								</div>
							</div>
						</article>
					</a>
				))}
			</div>
		</main>

		<Footer />
	</body>
</html>
