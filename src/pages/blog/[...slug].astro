---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_URL } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await render(post);

function categoryLabel(cat: string) {
	switch(cat) {
		case 'beauty-tech': return 'Beauty Tech';
		case 'dupes': return 'Dupes';
		case 'mens-grooming': return "Men's Grooming";
		case 'guides': return 'Guides';
		default: return cat;
	}
}

function categoryColor(cat: string) {
	switch(cat) {
		case 'beauty-tech': return 'text-rose-500 bg-rose-50';
		case 'dupes': return 'text-amber-600 bg-amber-50';
		case 'mens-grooming': return 'text-stone-600 bg-stone-100';
		case 'guides': return 'text-blue-600 bg-blue-50';
		default: return 'text-stone-600 bg-stone-100';
	}
}

const postUrl = `${SITE_URL}/blog/${post.id}`;
const ogImageUrl = `${SITE_URL}/og-default.png`;

// Breadcrumb schema
const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": SITE_URL
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Blog",
			"item": `${SITE_URL}/blog`
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": post.data.title
		}
	]
};

// Review schema (for posts with ratings)
const reviewSchema = post.data.rating ? {
	"@context": "https://schema.org",
	"@type": "Review",
	"name": post.data.title,
	"description": post.data.description,
	"url": postUrl,
	"datePublished": post.data.pubDate.toISOString(),
	...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
	"author": { "@type": "Organization", "name": "BeautyDupe", "url": SITE_URL },
	"publisher": { "@type": "Organization", "name": "BeautyDupe", "url": SITE_URL, "logo": { "@type": "ImageObject", "url": `${SITE_URL}/favicon.svg` } },
	"image": ogImageUrl,
	"reviewRating": {
		"@type": "Rating",
		"ratingValue": post.data.rating,
		"bestRating": 5,
		"worstRating": 1
	},
	...(post.data.price && {
		"itemReviewed": {
			"@type": "Product",
			"name": post.data.title.replace(' Review', '').replace(': ', ' - '),
			"image": ogImageUrl,
			"review": {
				"@type": "Review",
				"reviewRating": {
					"@type": "Rating",
					"ratingValue": post.data.rating,
					"bestRating": 5,
					"worstRating": 1
				},
				"author": { "@type": "Organization", "name": "BeautyDupe" }
			},
			"offers": {
				"@type": "Offer",
				"price": post.data.price.replace('$', '').split('–')[0].split('-')[0],
				"priceCurrency": "USD",
				"availability": "https://schema.org/InStock"
			}
		}
	})
} : null;

// Article schema (for posts WITHOUT ratings — dupe guides, roundups)
const articleSchema = !post.data.rating ? {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": post.data.title,
	"description": post.data.description,
	"url": postUrl,
	"image": ogImageUrl,
	"datePublished": post.data.pubDate.toISOString(),
	...(post.data.updatedDate && { "dateModified": post.data.updatedDate.toISOString() }),
	"author": { "@type": "Organization", "name": "BeautyDupe", "url": SITE_URL },
	"publisher": {
		"@type": "Organization",
		"name": "BeautyDupe",
		"url": SITE_URL,
		"logo": { "@type": "ImageObject", "url": `${SITE_URL}/favicon.svg` }
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": postUrl
	}
} : null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${post.data.title} — ${SITE_TITLE}`} description={post.data.description} type="article" />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{reviewSchema && (
			<script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />
		)}
		{articleSchema && (
			<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		)}
	</head>
	<body class="bg-white font-sans text-stone-900 antialiased">
		<Header />

		<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<!-- Breadcrumb Navigation -->
			<nav aria-label="Breadcrumb" class="mb-8">
				<ol class="flex items-center gap-1.5 text-sm text-stone-400">
					<li>
						<a href="/" class="hover:text-rose-500 no-underline transition-colors">Home</a>
					</li>
					<li aria-hidden="true" class="select-none">/</li>
					<li>
						<a href="/blog" class="hover:text-rose-500 no-underline transition-colors">Blog</a>
					</li>
					<li aria-hidden="true" class="select-none">/</li>
					<li class="text-stone-600 font-medium truncate max-w-[200px] sm:max-w-none" aria-current="page">
						{post.data.title}
					</li>
				</ol>
			</nav>

			<article>
				<!-- Header -->
				<header class="mb-10">
					<span class={`inline-block text-xs font-semibold px-2.5 py-1 rounded-full mb-4 ${categoryColor(post.data.category)}`}>
						{categoryLabel(post.data.category)}
					</span>
					<h1 class="text-3xl sm:text-4xl font-bold text-stone-900 leading-tight">{post.data.title}</h1>
					<p class="mt-3 text-stone-500">
						<time datetime={post.data.pubDate.toISOString()}>
							{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
						</time>
						{post.data.updatedDate && (
							<span class="italic text-stone-400">
								 · Updated <time datetime={post.data.updatedDate.toISOString()}>
									{post.data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
								</time>
							</span>
						)}
					</p>

					{post.data.price && (
						<p class="mt-4 text-lg font-semibold text-stone-800">Price: {post.data.price}</p>
					)}

					{post.data.rating && (
						<div class="mt-2 flex items-center gap-2">
							<span class="text-amber-500 text-lg">{'★'.repeat(Math.round(post.data.rating))}{'☆'.repeat(5 - Math.round(post.data.rating))}</span>
							<span class="text-sm text-stone-500">{post.data.rating}/5</span>
						</div>
					)}

					{post.data.dupeFor && (
						<p class="mt-3 text-sm text-stone-500">Dupe for: <span class="font-medium text-stone-700">{post.data.dupeFor}</span></p>
					)}
				</header>

				{post.data.heroImage ? (
					<div class="w-full h-64 sm:h-80 rounded-xl mb-10 overflow-hidden">
						<img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-contain" />
					</div>
				) : (
					<div class="w-full h-64 sm:h-80 bg-rose-50 rounded-xl mb-10 flex items-center justify-center">
						<span class="text-rose-200">Featured Image</span>
					</div>
				)}

				<!-- Pros / Cons -->
				{(post.data.pros || post.data.cons) && (
					<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10">
						{post.data.pros && (
							<div class="bg-green-50 rounded-lg p-5">
								<h3 class="font-semibold text-green-800 mb-3">Pros</h3>
								<ul class="space-y-1.5">
									{post.data.pros.map(pro => (
										<li class="text-sm text-green-700 flex items-start gap-2">
											<span class="text-green-500 mt-0.5">✓</span>
											<span>{pro}</span>
										</li>
									))}
								</ul>
							</div>
						)}
						{post.data.cons && (
							<div class="bg-red-50 rounded-lg p-5">
								<h3 class="font-semibold text-red-800 mb-3">Cons</h3>
								<ul class="space-y-1.5">
									{post.data.cons.map(con => (
										<li class="text-sm text-red-700 flex items-start gap-2">
											<span class="text-red-500 mt-0.5">✗</span>
											<span>{con}</span>
										</li>
									))}
								</ul>
							</div>
						)}
					</div>
				)}

				<!-- Content -->
				<div class="prose prose-stone prose-lg max-w-none prose-headings:font-bold prose-a:text-rose-500 prose-a:no-underline hover:prose-a:underline">
					<Content />
				</div>

				<!-- Affiliate link -->
				{post.data.affiliateLink && (
					<div class="mt-10 text-center">
						<a
							href={post.data.affiliateLink}
							target="_blank"
							rel="noopener noreferrer nofollow sponsored"
							class="inline-block bg-rose-500 text-white px-8 py-3 rounded-full font-semibold hover:bg-rose-600 transition-colors no-underline"
						>
							Check Price →
						</a>
					</div>
				)}

				<!-- Disclosure -->
				<div class="mt-12 p-5 bg-stone-50 rounded-lg border border-stone-200">
					<p class="text-xs text-stone-500">
						<strong class="text-stone-600">Affiliate Disclosure:</strong> BeautyDupe may earn a commission on purchases made through links in this article. This does not influence our ratings or editorial content. We only recommend products we genuinely believe in.
					</p>
				</div>
			</article>
		</main>

		<Footer />
	</body>
</html>
