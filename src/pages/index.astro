---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const beautyTech = posts.filter(p => p.data.category === 'beauty-tech').slice(0, 3);
const dupes = posts.filter(p => p.data.category === 'dupes').slice(0, 3);
const mensGrooming = posts.filter(p => p.data.category === 'mens-grooming').slice(0, 3);

function categoryLabel(cat: string) {
	switch(cat) {
		case 'beauty-tech': return 'Beauty Tech';
		case 'dupes': return 'Dupes';
		case 'mens-grooming': return "Men's Grooming";
		case 'guides': return 'Guides';
		default: return cat;
	}
}

const websiteSchema = {
	"@context": "https://schema.org",
	"@type": "WebSite",
	"name": SITE_TITLE,
	"url": SITE_URL,
	"description": SITE_DESCRIPTION,
	"inLanguage": "en-US",
	"potentialAction": {
		"@type": "SearchAction",
		"target": {
			"@type": "EntryPoint",
			"urlTemplate": `${SITE_URL}/blog?q={search_term_string}`
		},
		"query-input": "required name=search_term_string"
	}
};

const organizationSchema = {
	"@context": "https://schema.org",
	"@type": "Organization",
	"name": SITE_TITLE,
	"url": SITE_URL,
	"logo": `${SITE_URL}/favicon.svg`,
	"description": SITE_DESCRIPTION,
	"sameAs": []
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${SITE_TITLE} — Honest Beauty Reviews & Luxury Dupes`} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
	</head>
	<body class="bg-white font-sans text-stone-900 antialiased">
		<Header />

		<main>
			<!-- Hero -->
			<section class="bg-gradient-to-br from-rose-50 to-stone-50 py-20 sm:py-28">
				<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
					<h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight text-stone-900">
						Look expensive. <span class="text-rose-500">Spend less.</span>
					</h1>
					<p class="mt-6 text-lg sm:text-xl text-stone-600 max-w-2xl mx-auto">
						Beauty tech reviews, luxury dupes, and men's grooming — honest comparisons to help you look great without overspending.
					</p>
					<a href="/blog" class="mt-8 inline-block bg-rose-500 text-white px-6 py-3 rounded-full text-sm font-semibold hover:bg-rose-600 transition-colors no-underline">
						Read Reviews
					</a>
				</div>
			</section>

			<!-- Beauty Tech Section -->
			<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
				<div class="flex items-center justify-between mb-8">
					<h2 class="text-2xl sm:text-3xl font-bold text-stone-900">Beauty Tech</h2>
					<a href="/blog" class="text-sm font-medium text-rose-500 hover:text-rose-600 no-underline">View all &rarr;</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{beautyTech.map(post => (
						<a href={`/blog/${post.id}`} class="group no-underline">
							<article class="bg-white rounded-xl border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow">
								<div class="h-48 bg-rose-100 flex items-center justify-center overflow-hidden">
									{post.data.heroImage ? <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" /> : <span class="text-rose-300 text-sm">Image</span>}
								</div>
								<div class="p-5">
									<span class="inline-block text-xs font-semibold text-rose-500 bg-rose-50 px-2 py-1 rounded-full mb-3">Beauty Tech</span>
									<h3 class="font-semibold text-stone-900 group-hover:text-rose-500 transition-colors line-clamp-2">{post.data.title}</h3>
									<p class="mt-2 text-sm text-stone-500 line-clamp-2">{post.data.description}</p>
									{post.data.price && <p class="mt-3 text-sm font-semibold text-stone-700">{post.data.price}</p>}
								</div>
							</article>
						</a>
					))}
				</div>
			</section>

			<!-- Dupes Section -->
			<section class="bg-stone-50 py-16">
				<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
					<div class="flex items-center justify-between mb-8">
						<h2 class="text-2xl sm:text-3xl font-bold text-stone-900">Luxury Dupes</h2>
						<a href="/blog" class="text-sm font-medium text-rose-500 hover:text-rose-600 no-underline">View all &rarr;</a>
					</div>
					<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
						{dupes.map(post => (
							<a href={`/blog/${post.id}`} class="group no-underline">
								<article class="bg-white rounded-xl border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow">
									<div class="h-48 bg-amber-50 flex items-center justify-center overflow-hidden">
										{post.data.heroImage ? <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" /> : <span class="text-amber-300 text-sm">Image</span>}
									</div>
									<div class="p-5">
										<span class="inline-block text-xs font-semibold text-amber-600 bg-amber-50 px-2 py-1 rounded-full mb-3">Dupe</span>
										<h3 class="font-semibold text-stone-900 group-hover:text-rose-500 transition-colors line-clamp-2">{post.data.title}</h3>
										<p class="mt-2 text-sm text-stone-500 line-clamp-2">{post.data.description}</p>
										{post.data.dupeFor && <p class="mt-3 text-xs text-stone-400">Dupe for: {post.data.dupeFor}</p>}
									</div>
								</article>
							</a>
						))}
					</div>
				</div>
			</section>

			<!-- Men's Grooming Section -->
			<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
				<div class="flex items-center justify-between mb-8">
					<h2 class="text-2xl sm:text-3xl font-bold text-stone-900">Men's Grooming</h2>
					<a href="/blog" class="text-sm font-medium text-rose-500 hover:text-rose-600 no-underline">View all &rarr;</a>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
					{mensGrooming.map(post => (
						<a href={`/blog/${post.id}`} class="group no-underline">
							<article class="bg-white rounded-xl border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow">
								<div class="h-48 bg-stone-100 flex items-center justify-center overflow-hidden">
									{post.data.heroImage ? <img src={post.data.heroImage} alt={post.data.title} class="w-full h-full object-cover" /> : <span class="text-stone-300 text-sm">Image</span>}
								</div>
								<div class="p-5">
									<span class="inline-block text-xs font-semibold text-stone-600 bg-stone-100 px-2 py-1 rounded-full mb-3">Men's Grooming</span>
									<h3 class="font-semibold text-stone-900 group-hover:text-rose-500 transition-colors line-clamp-2">{post.data.title}</h3>
									<p class="mt-2 text-sm text-stone-500 line-clamp-2">{post.data.description}</p>
									{post.data.price && <p class="mt-3 text-sm font-semibold text-stone-700">{post.data.price}</p>}
								</div>
							</article>
						</a>
					))}
				</div>
			</section>
		</main>

		<Footer />
	</body>
</html>
