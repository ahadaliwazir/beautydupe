---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="About BeautyDupe — beauty tech reviews, dupe comparisons, and men's grooming guides." />
	</head>
	<body class="bg-white font-sans text-stone-900 antialiased">
		<Header />

		<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<h1 class="text-3xl sm:text-4xl font-bold text-stone-900 mb-8">About BeautyDupe</h1>

			<div class="prose prose-stone prose-lg max-w-none">
				<p>
					BeautyDupe is an independent review site dedicated to helping you navigate the overwhelming world of beauty products. We cover three areas we're passionate about:
				</p>

				<h2 class="text-2xl font-bold text-stone-900 mt-8 mb-4">Beauty Tech</h2>
				<p>
					From red light therapy wands to microcurrent devices, the beauty tech space is booming. We put these gadgets through weeks of real-world testing so you know what's worth the investment and what's just hype.
				</p>

				<h2 class="text-2xl font-bold text-stone-900 mt-8 mb-4">Luxury Dupes</h2>
				<p>
					We find affordable alternatives to cult-favorite luxury products. Every dupe we recommend is personally tested and compared side-by-side with the original. We'll always tell you when the dupe falls short — and when it's genuinely just as good.
				</p>

				<h2 class="text-2xl font-bold text-stone-900 mt-8 mb-4">Men's Grooming</h2>
				<p>
					Straightforward reviews of skincare, grooming tools, and grooming kits for men who want to look good without the nonsense. No gatekeeping, no fluff — just honest recommendations.
				</p>

				<h2 class="text-2xl font-bold text-stone-900 mt-8 mb-4">Our Process</h2>
				<p>
					We test every product for a minimum of two weeks before writing our review. Ratings are based on performance, value for money, build quality, and ease of use. We purchase most products ourselves, though we occasionally accept review units (always disclosed).
				</p>
			</div>

			<!-- Affiliate Disclosure -->
			<div class="mt-12 p-6 bg-stone-50 rounded-xl border border-stone-200">
				<h2 class="text-lg font-bold text-stone-900 mb-3">Affiliate Disclosure</h2>
				<p class="text-sm text-stone-600">
					BeautyDupe is reader-supported. When you buy through links on our site, we may earn an affiliate commission at no extra cost to you. This never influences our ratings or which products we recommend. Our editorial content is independent and honest — always.
				</p>
			</div>

			<!-- Contact -->
			<div class="mt-10 p-6 bg-rose-50 rounded-xl">
				<h2 class="text-lg font-bold text-stone-900 mb-3">Get in Touch</h2>
				<p class="text-sm text-stone-600">
					Have a product you'd like us to review? Questions about a recommendation? We'd love to hear from you.
				</p>
				<p class="mt-3">
					<a href="mailto:hello@beautydupe.com" class="text-rose-500 font-medium hover:text-rose-600 no-underline">
						hello@beautydupe.com
					</a>
				</p>
			</div>
		</main>

		<Footer />
	</body>
</html>
