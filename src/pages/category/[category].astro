---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_URL } from '../../consts';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
	const categories = ['beauty-tech', 'dupes', 'mens-grooming', 'guides'];
	const allPosts = await getCollection('blog');
	return categories.map((cat) => ({
		params: { category: cat },
		props: {
			category: cat,
			posts: allPosts
				.filter((post) => post.data.category === cat)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { category, posts } = Astro.props;

function categoryLabel(cat: string) {
	switch (cat) {
		case 'beauty-tech':
			return 'Beauty Tech';
		case 'dupes':
			return 'Dupes';
		case 'mens-grooming':
			return "Men's Grooming";
		case 'guides':
			return 'Guides';
		default:
			return cat;
	}
}

function categoryColor(cat: string) {
	switch (cat) {
		case 'beauty-tech':
			return 'text-rose-500 bg-rose-50';
		case 'dupes':
			return 'text-amber-600 bg-amber-50';
		case 'mens-grooming':
			return 'text-stone-600 bg-stone-100';
		case 'guides':
			return 'text-blue-600 bg-blue-50';
		default:
			return 'text-stone-600 bg-stone-100';
	}
}

const title = `${categoryLabel(category)} Articles — ${SITE_TITLE}`;
const description = `Browse all ${categoryLabel(category)} reviews, comparisons, and buying guides. Honest, tested recommendations for every budget.`;

const breadcrumbSchema = {
	"@context": "https://schema.org",
	"@type": "BreadcrumbList",
	"itemListElement": [
		{
			"@type": "ListItem",
			"position": 1,
			"name": "Home",
			"item": SITE_URL
		},
		{
			"@type": "ListItem",
			"position": 2,
			"name": "Blog",
			"item": `${SITE_URL}/blog`
		},
		{
			"@type": "ListItem",
			"position": 3,
			"name": categoryLabel(category)
		}
	]
};

const collectionPageSchema = {
	"@context": "https://schema.org",
	"@type": "CollectionPage",
	"name": title,
	"description": description,
	"url": `${SITE_URL}/category/${category}`,
	"isPartOf": {
		"@type": "WebSite",
		"name": SITE_TITLE,
		"url": SITE_URL
	}
};
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(collectionPageSchema)} />
	</head>
	<body class="bg-white font-sans text-stone-900 antialiased">
		<Header />

		<main class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
			<!-- Breadcrumb Navigation -->
			<nav aria-label="Breadcrumb" class="mb-6">
				<ol class="flex items-center gap-1.5 text-sm text-stone-400">
					<li>
						<a href="/" class="hover:text-rose-500 no-underline transition-colors">Home</a>
					</li>
					<li aria-hidden="true" class="select-none">/</li>
					<li>
						<a href="/blog" class="hover:text-rose-500 no-underline transition-colors">Blog</a>
					</li>
					<li aria-hidden="true" class="select-none">/</li>
					<li class="text-stone-600 font-medium" aria-current="page">{categoryLabel(category)}</li>
				</ol>
			</nav>

			<div class="mb-10">
				<h1 class="text-3xl sm:text-4xl font-bold text-stone-900">{categoryLabel(category)}</h1>
				<p class="mt-2 text-stone-500">Reviews, comparisons, and guides for {categoryLabel(category).toLowerCase()}.</p>
			</div>

			<!-- Category filters -->
			<div class="flex flex-wrap gap-2 mb-10">
				<a href="/blog" class="inline-block text-xs font-semibold text-stone-600 bg-stone-100 hover:bg-stone-200 px-3 py-1.5 rounded-full no-underline transition-colors">All</a>
				<a href="/category/beauty-tech" class={`inline-block text-xs font-semibold px-3 py-1.5 rounded-full no-underline transition-colors ${category === 'beauty-tech' ? 'text-rose-500 bg-rose-100 ring-2 ring-rose-300' : 'text-rose-500 bg-rose-50 hover:bg-rose-100'}`}>Beauty Tech</a>
				<a href="/category/dupes" class={`inline-block text-xs font-semibold px-3 py-1.5 rounded-full no-underline transition-colors ${category === 'dupes' ? 'text-amber-600 bg-amber-100 ring-2 ring-amber-300' : 'text-amber-600 bg-amber-50 hover:bg-amber-100'}`}>Dupes</a>
				<a href="/category/mens-grooming" class={`inline-block text-xs font-semibold px-3 py-1.5 rounded-full no-underline transition-colors ${category === 'mens-grooming' ? 'text-stone-700 bg-stone-200 ring-2 ring-stone-400' : 'text-stone-600 bg-stone-100 hover:bg-stone-200'}`}>Men's Grooming</a>
			</div>

			<!-- Posts grid -->
			{posts.length === 0 ? (
				<div class="text-center py-12">
					<p class="text-stone-500 text-lg">No articles found in this category yet.</p>
					<a href="/blog" class="mt-4 inline-block text-rose-500 font-medium hover:underline">View all articles</a>
				</div>
			) : (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
					{posts.map((post) => (
						<a href={`/blog/${post.id}`} class="group no-underline">
							<article class="bg-white rounded-xl border border-stone-200 overflow-hidden hover:shadow-lg transition-shadow h-full flex flex-col">
								<div class="h-44 bg-rose-50 flex items-center justify-center overflow-hidden shrink-0">
									{post.data.heroImage ? (
										<img src={post.data.heroImage} alt={post.data.title} loading="lazy" decoding="async" class="w-full h-full object-cover" />
									) : (
										<span class="text-rose-200 text-sm">Image</span>
									)}
								</div>
								<div class="p-5 flex flex-col flex-grow">
									<span class={`inline-block self-start text-xs font-semibold px-2 py-1 rounded-full mb-3 ${categoryColor(post.data.category)}`}>
										{categoryLabel(post.data.category)}
									</span>
									<h3 class="font-semibold text-stone-900 group-hover:text-rose-500 transition-colors line-clamp-2">{post.data.title}</h3>
									<p class="mt-2 text-sm text-stone-500 line-clamp-2 flex-grow">{post.data.description}</p>
									<div class="mt-3 flex items-center justify-between">
										{post.data.price && <span class="text-sm font-semibold text-stone-700">{post.data.price}</span>}
										{post.data.rating && (
											<span class="text-sm text-amber-500">
												{'★'.repeat(Math.round(post.data.rating))}
												{'☆'.repeat(5 - Math.round(post.data.rating))}
											</span>
										)}
									</div>
								</div>
							</article>
						</a>
					))}
				</div>
			)}
		</main>

		<Footer />
	</body>
</html>
